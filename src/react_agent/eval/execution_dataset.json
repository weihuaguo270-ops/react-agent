    "name": "calculator: 144/12",
    "tags": ["execution", "calculator"],
    "mode": "offline_tools",
    "steps": [
      {
        "tool": "calculator",
        "arguments": {"expression": "144 / 12"},
        "expect_equals": "12.0"
      }
